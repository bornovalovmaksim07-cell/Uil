# НАСТРОЙКА КАНАЛА ДЛЯ ОБЯЗАТЕЛЬНОЙ ПОДПИСКИ
CHANNEL_ID = -1004435328184  # ID канала @MagicCheatRessel
CHANNEL_LINK = "https://t.me/MagicCheatRessel"  # Ссылка на канал @MagicCheatRessel

# ХОЧЕШЬ ЛИ ТЕСТИРОВАТЬ ПОДПИСКУ НА СЕБЕ (АДМИНЕ)?
